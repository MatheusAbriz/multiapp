<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JoKenPo"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/textPlacar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PC x Jogador"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha do PC:"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/imageEscolhaPc"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/padrao"
        android:scaleType="centerInside"
        android:layout_marginBottom="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sua Escolha:"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <ImageButton
            android:id="@+id/btnPedra"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/pedra"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp"/>

        <ImageButton
            android:id="@+id/btnPapel"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/papel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp"/>

        <ImageButton
            android:id="@+id/btnTesoura"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/tesoura"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside" />
    </LinearLayout>

    <TextView
        android:id="@+id/textResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha uma opção para começar!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:textAlignment="center"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnReiniciar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reiniciar Partida"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVoltarJokenpo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voltar ao Menu" />

</LinearLayout>